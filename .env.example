APP_ENV=development
APP_NAME=nivas

SERVER_HOST=0.0.0.0
SERVER_PORT=8080

DATABASE_URL=postgres://postgres:postgres@localhost:5432/nivas?sslmode=disable

JWT_SECRET=change-me-in-development
JWT_ACCESS_TTL=15m
JWT_STAFF_REFRESH_TTL=168h
JWT_TENANT_REFRESH_TTL=720h

RATE_LIMIT_AUTH_REQUESTS=10
RATE_LIMIT_AUTH_WINDOW=1m

CORS_ALLOWED_ORIGINS=http://localhost:5173

RESEND_API_KEY=
EMAIL_FROM=Nivas <onboarding@resend.dev>
FRONTEND_URL=http://localhost:5173
PASSWORD_RESET_TTL=1h
EMAIL_DEV_REDIRECT_TO=

RENT_REMINDER_DUE_DAY=5
RENT_REMINDER_OVERDUE_DAY=10
RENT_REMINDER_CRON=0 9 * * *

# Document storage (local filesystem by default; set STORAGE_DRIVER=s3 for S3/MinIO)
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./data/documents
MAX_UPLOAD_BYTES=10485760
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=nivas-documents
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_REGION=us-east-1
# S3_USE_PATH_STYLE=true
# S3_PRESIGN_TTL=15m

LOG_LEVEL=info
LOG_FORMAT=text

# First owner (run: make bootstrap)
BOOTSTRAP_ORG_ID=00000000-0000-0000-0000-000000000001
BOOTSTRAP_EMAIL=owner@nivas.local
BOOTSTRAP_PASSWORD=admin123